# Shared test runner image for local runs and GitHub Actions.
#
# This image contains only the Lua 5.1 toolchain and busted. The repository is
# mounted at runtime so normal code or test changes do not require rebuilding
# the image.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        git \
        liblua5.1-0-dev \
        lua5.1 \
        luarocks \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

RUN luarocks --lua-version=5.1 install busted

ENTRYPOINT ["busted"]