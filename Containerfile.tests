FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        git \
        liblua5.1-0-dev \
        lua5.1 \
        luarocks \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

RUN luarocks --lua-version=5.1 install busted

ENTRYPOINT ["busted"]